{
  "$schema": "https://aka.ms/azure/static-web-apps-cli/schema",
  "configurations": {
    "summercafe2026": {
      "appLocation": "src/Client",
      "apiLocation": "api",
      "outputLocation": "bin/wwwroot",
      "apiLanguage": "dotnetisolated",
      "apiVersion": "10.0",
      "appBuildCommand": "dotnet publish -c Release -o bin",
      "apiBuildCommand": "dotnet publish -c Release",
      "run": "dotnet watch run",
      "appDevserverUrl": "http://localhost:5297",
      "apiPort": 7071,
      "apiDevserverUrl": "http://localhost:7071",
      "auth": {
        "identityProviders": {
          "azureActiveDirectory": {
            "userDetailsClaim": "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"
          }
        }
      }
    }
  }
}