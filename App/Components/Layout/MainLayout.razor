@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<BlazorApp1.Components.Shared.ErrorBoundary>
    <div class="page-shell">
        <aside class="app-sidebar @(menuExpanded ? "app-sidebar-expanded" : string.Empty)">
            <NavMenu IsExpanded="menuExpanded" OnToggle="ToggleMenu" />
        </aside>

        @if (menuExpanded)
        {
            <button class="sidebar-backdrop" @onclick="CollapseMenu" type="button" aria-label="Close navigation"></button>
        }

        <main class="app-main">
            <div class="app-content">
                @Body
            </div>
        </main>
    </div>
</BlazorApp1.Components.Shared.ErrorBoundary>

@code {
    private bool menuExpanded;

    private void ToggleMenu()
    {
        menuExpanded = !menuExpanded;
    }

    private void CollapseMenu()
    {
        menuExpanded = false;
    }
}