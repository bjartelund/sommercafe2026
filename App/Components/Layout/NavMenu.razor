<div class="nav-shell @(IsExpanded ? "nav-expanded" : "nav-collapsed")">
    <div class="nav-header">
        <button class="nav-toggle" @onclick="OnToggle" type="button" aria-label="Toggle navigation">
            <MudIcon Icon="@(IsExpanded ? Icons.Material.Filled.ChevronLeft : Icons.Material.Filled.Menu)" />
        </button>

        <div class="nav-brand">
            <MudIcon Icon="@Icons.Material.Filled.LocalCafe" Class="nav-brand-icon" />
            <span class="nav-brand-text">Summer Café</span>
        </div>
    </div>

    <MudNavMenu Class="nav-links" Dense="true">
        <MudNavLink Href="orders" Icon="@Icons.Material.Filled.ShoppingCart" Match="NavLinkMatch.Prefix" Class="nav-link" title="Orders">
            <span class="nav-link-text">Orders</span>
        </MudNavLink>
        <MudNavLink Href="products" Icon="@Icons.Material.Filled.Inventory" Match="NavLinkMatch.Prefix" Class="nav-link" title="Products">
            <span class="nav-link-text">Products</span>
        </MudNavLink>
        <MudNavLink Href="expenses" Icon="@Icons.Material.Filled.Receipt" Match="NavLinkMatch.Prefix" Class="nav-link" title="Expenses">
            <span class="nav-link-text">Expenses</span>
        </MudNavLink>
        <MudNavLink Href="ledger" Icon="@Icons.Material.Filled.ReceiptLong" Match="NavLinkMatch.Prefix" Class="nav-link" title="Ledger">
            <span class="nav-link-text">Ledger</span>
        </MudNavLink>
        <MudNavLink Href="work-hours" Icon="@Icons.Material.Filled.Schedule" Match="NavLinkMatch.Prefix" Class="nav-link" title="Work Hours">
            <span class="nav-link-text">Work Hours</span>
        </MudNavLink>
    </MudNavMenu>
</div>

@code {
    [Parameter] public bool IsExpanded { get; set; }

    [Parameter] public EventCallback OnToggle { get; set; }
}