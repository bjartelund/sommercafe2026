@inherits ErrorBoundaryBase

@if (CurrentException != null)
{
    <div style="padding: 2rem; background-color: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; margin: 1rem;">
        <h3 style="color: #856404; margin-top: 0;">⚠️ Component Error</h3>
        <p style="color: #856404; margin-bottom: 0;">
            A component encountered an unexpected error. Try refreshing the page.
        </p>
    </div>
}
else
{
    @ChildContent
}

@code {
    protected override Task OnErrorAsync(Exception exception)
    {
        return Task.CompletedTask;
    }
}
