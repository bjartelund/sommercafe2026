@page "/work-hours"
@using BlazorApp1.Services
@using BlazorApp1.Components.Pages.WorkHours.Components
@using MudBlazor
@inject WorkSessionsService WorkSessionsService
@inject IDialogService DialogService

<PageTitle>Work Hours</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">Log Work Hours</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenAddDialog" Class="mb-6">
    Log Hours
</MudButton>

@if (loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    <MudText Class="mt-4">Loading work sessions...</MudText>
}
else if (sessions.Count == 0)
{
    <MudAlert Severity="Severity.Info">No work sessions logged yet.</MudAlert>
}
else
{
    <MudPaper Class="pa-6">
        <MudTable Items="sessions" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>Employee</MudTh>
                <MudTh>Start Time</MudTh>
                <MudTh>End Time</MudTh>
                <MudTh Align="Align.Right">Duration</MudTh>
                <MudTh Align="Align.Right">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.SessionDate.ToString("MMM dd, yyyy")</MudTd>
                <MudTd>@(context.Employee?.DisplayName ?? "Unknown")</MudTd>
                <MudTd>@context.StartTime.ToString(@"hh\:mm")</MudTd>
                <MudTd>@context.EndTime.ToString(@"hh\:mm")</MudTd>
                <MudTd Align="Align.Right">@FormatDuration(context.DurationMinutes)</MudTd>
                <MudTd Align="Align.Right">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() => OpenEditDialog(context)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => ConfirmDelete(context)" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    private List<WorkSessionResponse> sessions = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadSessions();
    }

    private async Task LoadSessions()
    {
        loading = true;
        var today = DateTime.UtcNow.Date;
        sessions = await WorkSessionsService.GetWorkSessionsAsync(today.AddMonths(-1), today.AddDays(1));
        sessions = sessions.OrderByDescending(s => s.SessionDate).ToList();
        loading = false;
    }

    private async Task OpenAddDialog()
    {
        var dialog = await DialogService.ShowAsync<WorkSessionForm>("", new DialogParameters { { "IsEdit", false } });
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var (date, start, end, notes) = ((DateTime, TimeSpan, TimeSpan, string?))result.Data;
            var session = await WorkSessionsService.CreateWorkSessionAsync(date, start, end, notes);
            if (session != null)
            {
                sessions.Add(session);
                sessions = sessions.OrderByDescending(s => s.SessionDate).ToList();
            }
        }
    }

    private async Task OpenEditDialog(WorkSessionResponse session)
    {
        var parameters = new DialogParameters
        {
            { "IsEdit", true },
            { "InitialDate", session.SessionDate.ToString("yyyy-MM-dd") },
            { "InitialStartTime", session.StartTime },
            { "InitialEndTime", session.EndTime },
            { "InitialNotes", session.Notes }
        };

        var dialog = await DialogService.ShowAsync<WorkSessionForm>("", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var (date, start, end, notes) = ((DateTime, TimeSpan, TimeSpan, string?))result.Data;
            var updated = await WorkSessionsService.UpdateWorkSessionAsync(session.Id, date, start, end, notes);
            if (updated != null)
            {
                var index = sessions.FindIndex(s => s.Id == session.Id);
                if (index >= 0)
                {
                    sessions[index] = updated;
                    sessions = sessions.OrderByDescending(s => s.SessionDate).ToList();
                }
            }
        }
    }

    private async Task ConfirmDelete(WorkSessionResponse session)
    {
        var parameters = new DialogParameters { { "Message", $"Delete work session from {session.SessionDate:MMM dd}?" } };
        var dialog = await DialogService.ShowAsync<BlazorApp1.Components.Pages.Expenses.Components.ConfirmDeleteDialog>("", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            if (await WorkSessionsService.DeleteWorkSessionAsync(session.Id))
            {
                sessions.Remove(session);
            }
        }
    }

    private string FormatDuration(int minutes)
    {
        var hours = minutes / 60;
        var mins = minutes % 60;
        if (hours > 0)
            return $"{hours}h {mins}m";
        return $"{mins}m";
    }
}
