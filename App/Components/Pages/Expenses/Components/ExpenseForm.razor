@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Edit Expense" : "Add Expense")</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="Description" Label="Description" Variant="Variant.Outlined" Required="true" />
            <MudNumericField @bind-Value="Amount" Label="Amount" Variant="Variant.Outlined" Format="C2" Min="0.01m" Required="true" />
            <label>Date</label>
            <input type="date" value="@DateString" @onchange="(ChangeEventArgs e) => DateString = e.Value?.ToString() ?? string.Empty" max="@DateTime.UtcNow.Date.ToString("yyyy-MM-dd")" class="mud-input-base mud-input mud-input-outlined" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Save" Disabled="!IsValid">
            @(IsEdit ? "Update" : "Add")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string? InitialDescription { get; set; }

    [Parameter]
    public decimal InitialAmount { get; set; }

    [Parameter]
    public string? InitialDate { get; set; }

    [Parameter]
    public bool IsEdit { get; set; }

    private string? Description;
    private decimal Amount;
    private string DateString = "";

    protected override void OnInitialized()
    {
        Description = InitialDescription;
        Amount = InitialAmount;
        DateString = InitialDate ?? DateTime.UtcNow.Date.ToString("yyyy-MM-dd");
    }

    private bool IsValid => !string.IsNullOrWhiteSpace(Description) && Amount > 0 && !string.IsNullOrWhiteSpace(DateString);

    private void Cancel() => MudDialog.Cancel();

    private void Save()
    {
        if (IsValid && DateTime.TryParseExact(DateString, "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out var date))
        {
            MudDialog.Close(DialogResult.Ok((Description, Amount, date)));
        }
    }
}
