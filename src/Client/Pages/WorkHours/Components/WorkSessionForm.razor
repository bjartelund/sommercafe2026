@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Edit Work Session" : "Log Work Hours")</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <div>
                <label>Date</label>
                <input type="date" value="@DateString" @onchange="(ChangeEventArgs e) => DateString = e.Value?.ToString() ?? string.Empty" class="mud-input-base mud-input mud-input-outlined" style="width: 100%; padding: 8px;" />
            </div>
            <div>
                <label>Start Time</label>
                <input type="time" value="@StartTimeString" @onchange="(ChangeEventArgs e) => StartTimeString = e.Value?.ToString() ?? string.Empty" class="mud-input-base mud-input mud-input-outlined" style="width: 100%; padding: 8px;" />
            </div>
            <div>
                <label>End Time</label>
                <input type="time" value="@EndTimeString" @onchange="(ChangeEventArgs e) => EndTimeString = e.Value?.ToString() ?? string.Empty" class="mud-input-base mud-input mud-input-outlined" style="width: 100%; padding: 8px;" />
            </div>
            @if (DurationMinutes > 0)
            {
                <MudAlert Severity="Severity.Info">
                    Duration: @FormatDuration(DurationMinutes)
                </MudAlert>
            }
            <MudTextField @bind-Value="Notes" Label="Notes (optional)" Variant="Variant.Outlined" Lines="3" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Save" Disabled="!IsValid">
            @(IsEdit ? "Update" : "Log Hours")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string? InitialDate { get; set; }

    [Parameter]
    public TimeSpan InitialStartTime { get; set; }

    [Parameter]
    public TimeSpan InitialEndTime { get; set; }

    [Parameter]
    public string? InitialNotes { get; set; }

    [Parameter]
    public bool IsEdit { get; set; }

    private string DateString = "";
    private string StartTimeString = "";
    private string EndTimeString = "";
    private string? Notes;

    protected override void OnInitialized()
    {
        DateString = InitialDate ?? DateTime.UtcNow.Date.ToString("yyyy-MM-dd");
        StartTimeString = InitialStartTime.ToString(@"hh\:mm");
        EndTimeString = InitialEndTime.ToString(@"hh\:mm");
        Notes = InitialNotes;
    }

    private int DurationMinutes
    {
        get
        {
            if (TimeSpan.TryParse(StartTimeString, out var start) && TimeSpan.TryParse(EndTimeString, out var end) && end > start)
            {
                return (int)(end - start).TotalMinutes;
            }
            return 0;
        }
    }

    private string FormatDuration(int minutes)
    {
        var hours = minutes / 60;
        var mins = minutes % 60;
        if (hours > 0)
            return $"{hours}h {mins}m";
        return $"{mins}m";
    }

    private bool IsValid
    {
        get
        {
            return !string.IsNullOrWhiteSpace(DateString) &&
                   !string.IsNullOrWhiteSpace(StartTimeString) &&
                   !string.IsNullOrWhiteSpace(EndTimeString) &&
                   TimeSpan.TryParse(StartTimeString, out var start) &&
                   TimeSpan.TryParse(EndTimeString, out var end) &&
                   end > start;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Save()
    {
        if (IsValid &&
            DateTime.TryParseExact(DateString, "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out var date) &&
            TimeSpan.TryParse(StartTimeString, out var start) &&
            TimeSpan.TryParse(EndTimeString, out var end))
        {
            MudDialog.Close(DialogResult.Ok((date, start, end, Notes)));
        }
    }
}
