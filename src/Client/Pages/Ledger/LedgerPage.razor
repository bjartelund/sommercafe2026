@page "/ledger"
@using Client.Services
@using MudBlazor
@inject LedgerService LedgerService
@inject OrdersService OrdersService
@inject NavigationManager Navigation

<PageTitle>Financial Ledger</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">Financial Ledger</MudText>

<MudPaper Class="pa-6 mb-6">
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudDatePicker Label="From" @bind-Date="fromDate" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudDatePicker Label="To" @bind-Date="toDate" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RefreshLedger" FullWidth="true">
                Apply Filter
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    <MudText Class="mt-4">Loading ledger...</MudText>
}
else if (ledger == null)
{
    <MudAlert Severity="Severity.Error">Failed to load ledger data.</MudAlert>
}
else
{
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.subtitle1">Total Revenue</MudText>
                <MudText Typo="Typo.h5" Color="Color.Success">@ledger.TotalRevenue.ToString("C")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.subtitle1">Total Expenses</MudText>
                <MudText Typo="Typo.h5" Color="Color.Error">@ledger.TotalExpenses.ToString("C")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.subtitle1">Net Balance</MudText>
                <MudText Typo="Typo.h5" Color="@(ledger.NetBalance >= 0 ? Color.Success : Color.Error)">
                    @ledger.NetBalance.ToString("C")
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-6">
        <MudTable Items="ledger.Entries" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Description</MudTh>
                <MudTh Align="Align.Right">Amount</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="cursor: pointer;" @onclick="() => OnEntryClick(context)">
                    @context.Date.ToString("MMM dd, yyyy")
                </MudTd>
                <MudTd @onclick="() => OnEntryClick(context)" Style="cursor: pointer;">
                    @context.Type
                </MudTd>
                <MudTd @onclick="() => OnEntryClick(context)" Style="cursor: pointer;">
                    @(context.Description ?? (context.Type == "Order" ? "Order" : "—"))
                </MudTd>
                <MudTd Align="Align.Right" Style="cursor: pointer;" @onclick="() => OnEntryClick(context)">
                    <MudText Color="@(context.Amount > 0 ? Color.Success : Color.Error)">
                        @(context.Amount > 0 ? "+" : "")@context.Amount.ToString("C")
                    </MudText>
                </MudTd>
            </RowTemplate>
        </MudTable>

        @if (ledger.Entries.Count == 0)
        {
            <MudText Align="Align.Center" Class="mt-4">No entries for the selected date range.</MudText>
        }
    </MudPaper>
}

@code {
    private LedgerResponseData? ledger;
    private DateTime? fromDate;
    private DateTime? toDate;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.UtcNow.Date;
        fromDate = today.AddMonths(-3);
        toDate = today.AddDays(1);

        await RefreshLedger();
    }

    private async Task RefreshLedger()
    {
        loading = true;
        ledger = await LedgerService.GetLedgerAsync(fromDate, toDate);
        loading = false;
    }

    private void OnEntryClick(LedgerEntryResponse entry)
    {
        if (entry.Type == "Order")
        {
            Navigation.NavigateTo($"/order-detail/{entry.EntityId}");
        }
    }
}
