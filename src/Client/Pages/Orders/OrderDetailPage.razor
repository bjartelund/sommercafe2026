@page "/order-detail/{Id:int}"
@using Client.Services
@using MudBlazor
@inject OrdersService OrdersService
@inject NavigationManager Navigation

<PageTitle>Order Details</PageTitle>

<MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack">
    Back
</MudButton>

@if (loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    <MudText Class="mt-4">Loading order...</MudText>
}
else if (order == null)
{
    <MudAlert Severity="Severity.Error">Order not found.</MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-6">Order #@order.Id</MudText>

    <MudPaper Class="pa-6 mb-6">
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2">Placed At</MudText>
                <MudText Typo="Typo.body1">@order.PlacedAt.ToString("g")</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2">Total Amount</MudText>
                <MudText Typo="Typo.body1">@order.TotalAmount.ToString("C")</MudText>
            </MudItem>
            @if (!string.IsNullOrEmpty(order.Notes))
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2">Notes</MudText>
                    <MudText Typo="Typo.body1">@order.Notes</MudText>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>

    <MudText Typo="Typo.h6" Class="mb-4">Order Lines</MudText>
    <MudPaper Class="pa-6">
        <MudTable Items="order.OrderLines" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Product</MudTh>
                <MudTh Align="Align.Right">Unit Price</MudTh>
                <MudTh Align="Align.Right">Quantity</MudTh>
                <MudTh Align="Align.Right">Line Total</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ProductName</MudTd>
                <MudTd Align="Align.Right">@context.UnitPrice.ToString("C")</MudTd>
                <MudTd Align="Align.Right">@context.Quantity</MudTd>
                <MudTd Align="Align.Right">@context.LineTotal.ToString("C")</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private OrderResponse? order;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        order = await OrdersService.GetOrderAsync(Id);
        loading = false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/ledger");
    }
}
