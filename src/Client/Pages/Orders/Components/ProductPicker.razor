@using Client.Services
@using MudBlazor

<MudCard>
    <MudCardHeader>
        <MudText Typo="Typo.h6">Available Products</MudText>
    </MudCardHeader>
    <MudCardContent>
        @if (Products == null || Products.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No products available</MudAlert>
        }
        else
        {
            <MudGrid>
                @foreach (var product in Products)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Class="pa-4" Outlined="true" Style="height: 100%; display: flex; flex-direction: column;">
                            <MudText Typo="Typo.body1" Class="mb-2"><strong>@product.Name</strong></MudText>
                            <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-4">
                                @product.Price.ToString("N2") kr
                            </MudText>

                            <div style="display: flex; gap: 4px; align-items: center; mb: 1rem;">
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => { if (quantities[product.Id] > 1) quantities[product.Id]--; })" Style="min-width: 32px;">−</MudButton>
                                <span style="flex: 1; text-align: center;">@quantities[product.Id]</span>
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => quantities[product.Id]++)" Style="min-width: 32px;">+</MudButton>
                            </div>

                            <MudButton Variant="Variant.Filled"
                                      Color="Color.Primary"
                                      FullWidth="true"
                                      OnClick="@(() => AddProductToOrder(product.Id))">
                                Add to Order
                            </MudButton>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public List<ProductResponse> Products { get; set; } = new();

    [Parameter]
    public EventCallback<(int ProductId, int Quantity)> OnLineAdded { get; set; }

    [Parameter]
    public EventCallback<int> OnLineRemoved { get; set; }

    private Dictionary<int, int> quantities = new();

    protected override void OnParametersSet()
    {
        quantities.Clear();
        foreach (var product in Products)
        {
            if (!quantities.ContainsKey(product.Id))
            {
                quantities[product.Id] = 1;
            }
        }
    }

    private async Task AddProductToOrder(int productId)
    {
        if (quantities.TryGetValue(productId, out var qty) && qty > 0)
        {
            await OnLineAdded.InvokeAsync((productId, qty));
            quantities[productId] = 1;
        }
    }
}
