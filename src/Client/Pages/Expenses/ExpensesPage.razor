@page "/expenses"
@using Client.Services
@using Client.Pages.Expenses.Components
@using MudBlazor
@inject ExpensesService ExpensesService
@inject IDialogService DialogService

<PageTitle>Record Expenses</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">Record Expenses</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenAddDialog" Class="mb-6">
    Add Expense
</MudButton>

@if (loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    <MudText Class="mt-4">Loading expenses...</MudText>
}
else if (expenses.Count == 0)
{
    <MudAlert Severity="Severity.Info">No expenses recorded yet.</MudAlert>
}
else
{
    <MudPaper Class="pa-6">
        <MudTable Items="expenses" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>Description</MudTh>
                <MudTh Align="Align.Right">Amount</MudTh>
                <MudTh Align="Align.Right">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ExpenseDate.ToString("MMM dd, yyyy")</MudTd>
                <MudTd>@context.Description</MudTd>
                <MudTd Align="Align.Right">@context.Amount.ToString("C")</MudTd>
                <MudTd Align="Align.Right">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() => OpenEditDialog(context)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => ConfirmDelete(context)" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    private List<ExpenseResponse> expenses = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadExpenses();
    }

    private async Task LoadExpenses()
    {
        loading = true;
        var today = DateTime.UtcNow.Date;
        expenses = await ExpensesService.GetExpensesAsync(today.AddMonths(-3), today.AddDays(1));
        loading = false;
    }

    private async Task OpenAddDialog()
    {
        var dialog = await DialogService.ShowAsync<ExpenseForm>("", new DialogParameters { { "IsEdit", false } });
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var (description, amount, date) = ((string, decimal, DateTime))result.Data;
            var expense = await ExpensesService.CreateExpenseAsync(description, amount, date);
            if (expense != null)
            {
                expenses.Add(expense);
                expenses = expenses.OrderByDescending(e => e.ExpenseDate).ToList();
            }
        }
    }

    private async Task OpenEditDialog(ExpenseResponse expense)
    {
        var parameters = new DialogParameters
        {
            { "IsEdit", true },
            { "InitialDescription", expense.Description },
            { "InitialAmount", expense.Amount },
            { "InitialDate", expense.ExpenseDate.ToString("yyyy-MM-dd") }
        };

        var dialog = await DialogService.ShowAsync<ExpenseForm>("", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var (description, amount, date) = ((string, decimal, DateTime))result.Data;
            var updated = await ExpensesService.UpdateExpenseAsync(expense.Id, description, amount, date);
            if (updated != null)
            {
                var index = expenses.FindIndex(e => e.Id == expense.Id);
                if (index >= 0)
                {
                    expenses[index] = updated;
                    expenses = expenses.OrderByDescending(e => e.ExpenseDate).ToList();
                }
            }
        }
    }

    private async Task ConfirmDelete(ExpenseResponse expense)
    {
        var parameters = new DialogParameters { { "Message", $"Delete expense '{expense.Description}'?" } };
        var dialog = await DialogService.ShowAsync<ConfirmDeleteDialog>("", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            if (await ExpensesService.DeleteExpenseAsync(expense.Id))
            {
                expenses.Remove(expense);
            }
        }
    }
}
