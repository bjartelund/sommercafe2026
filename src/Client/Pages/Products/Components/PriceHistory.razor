@using System.Net.Http.Json
@using MudBlazor
@inject HttpClient HttpClient

@if (loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    <MudText Class="mt-2">Loading price history...</MudText>
}
else if (historyEntries.Count == 0)
{
    <MudAlert Severity="Severity.Info">No price history available.</MudAlert>
}
else
{
    <MudTable Items="historyEntries.OrderByDescending(h => h.SysStartTime).ToList()" Striped="true" Bordered="true" Dense="true">
        <HeaderContent>
            <MudTh Align="Align.Right">Price</MudTh>
            <MudTh>Valid From</MudTh>
            <MudTh>Valid Until</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Align="Align.Right">@context.Price.ToString("C")</MudTd>
            <MudTd>@context.SysStartTime.ToString("g")</MudTd>
            <MudTd>@(context.SysEndTime == DateTime.MaxValue ? "Current" : context.SysEndTime.ToString("g"))</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter]
    public int ProductId { get; set; }

    private List<PriceHistoryEntry> historyEntries = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPriceHistory();
    }

    private async Task LoadPriceHistory()
    {
        loading = true;
        try
        {
            var entries = await HttpClient.GetFromJsonAsync<List<PriceHistoryEntry>>($"/api/products/{ProductId}/price-history");
            historyEntries = entries ?? new();
        }
        catch
        {
            // Silently fail for now
        }
        loading = false;
    }

    private class PriceHistoryEntry
    {
        public decimal Price { get; set; }
        public DateTime SysStartTime { get; set; }
        public DateTime SysEndTime { get; set; }
    }
}
