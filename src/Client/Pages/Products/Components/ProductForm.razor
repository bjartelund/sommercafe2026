@using Client.Services
@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(Product == null ? "Add Product" : "Edit Price")</MudText>
    </TitleContent>
    <DialogContent>
        @if (Product == null)
        {
            <MudTextField @bind-Value="formName"
                         Label="Product Name"
                         Placeholder="e.g., Coffee"
                         Variant="Variant.Outlined"
                         Class="mb-4" />
        }

        <MudNumericField @bind-Value="formPrice"
                        Label="Price"
                        Variant="Variant.Outlined"
                        Min="0.01m"
                        Step="0.01m"
                        HelperText="@(formPrice <= 0 ? "Price must be greater than 0" : "")"
                        Error="@(formPrice <= 0)"
                        Class="mb-4" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="HandleCancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                  Color="Color.Primary"
                  Disabled="@(string.IsNullOrWhiteSpace(formName) && Product == null || formPrice <= 0)"
                  OnClick="HandleSubmit">
            @(Product == null ? "Add" : "Update Price")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public ProductResponse? Product { get; set; }

    [Parameter]
    public EventCallback<ProductResponse> OnSave { get; set; }

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    private string formName = "";
    private decimal formPrice = 0;

    protected override void OnParametersSet()
    {
        if (Product != null)
        {
            formName = Product.Name ?? "";
            formPrice = Product.Price;
        }
        else
        {
            formName = "";
            formPrice = 0;
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(formName) && Product == null)
            return;
        if (formPrice <= 0)
            return;

        var newProduct = new ProductResponse
        {
            Id = Product?.Id ?? 0,
            Name = formName,
            Price = formPrice,
            IsActive = Product?.IsActive ?? true,
            CreatedAt = Product?.CreatedAt ?? DateTime.UtcNow
        };

        await OnSave.InvokeAsync(newProduct);
        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task HandleCancel()
    {
        await IsOpenChanged.InvokeAsync(false);
    }
}
