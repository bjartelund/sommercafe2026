@page "/products"
@using Client.Services
@using Client.Pages.Products.Components
@using MudBlazor
@inject ProductsService ProductsService

<PageTitle>Manage Products</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">Product Catalogue</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenAddForm" Class="mb-4">
    Add Product
</MudButton>

@if (loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (allProducts.Count == 0)
{
    <MudAlert Severity="Severity.Info">
        No products yet. <MudLink OnClick="OpenAddForm">Add one</MudLink>.
    </MudAlert>
}
else
{
    <MudTable Items="allProducts" Striped="true" Bordered="true" Dense="false">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh Align="Align.Right">Price</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Align="Align.Center">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd Align="Align.Right">@context.Price.ToString("C")</MudTd>
            <MudTd>
                @if (context.IsActive)
                {
                    <MudChip Color="Color.Success" Size="Size.Small">Active</MudChip>
                }
                else
                {
                    <MudChip Color="Color.Error" Size="Size.Small">Inactive</MudChip>
                }
            </MudTd>
            <MudTd Align="Align.Center">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => OpenEditForm(context))">Edit</MudButton>
                <MudButton Variant="Variant.Outlined"
                          Color="@(context.IsActive ? Color.Error : Color.Success)"
                          Size="Size.Small"
                          OnClick="@(() => ToggleActive(context))">
                    @(context.IsActive ? "Deactivate" : "Reactivate")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => ShowHistory(context))">History</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<ProductForm @bind-IsOpen="showForm" Product="editingProduct" OnSave="SaveProduct" />

<MudDialog @bind-IsOpen="showHistory" MaxWidth="MaxWidth.Small">
    <TitleContent>
        <MudText Typo="Typo.h6">Price History: @historyProduct?.Name</MudText>
    </TitleContent>
    <DialogContent>
        @if (historyProduct != null)
        {
            <PriceHistory ProductId="historyProduct.Id" />
        }
    </DialogContent>
</MudDialog>

@code {
    private List<ProductResponse> allProducts = new();
    private ProductResponse? editingProduct;
    private ProductResponse? historyProduct;
    private bool loading = true;
    private bool showForm = false;
    private bool showHistory = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        loading = true;
        var active = await ProductsService.GetActiveProductsAsync();
        allProducts = active;
        loading = false;
    }

    private void OpenAddForm()
    {
        editingProduct = null;
        showForm = true;
    }

    private void OpenEditForm(ProductResponse product)
    {
        editingProduct = product;
        showForm = true;
    }

    private async Task SaveProduct(ProductResponse product)
    {
        if (editingProduct == null)
        {
            var result = await ProductsService.CreateProductAsync(product.Name ?? "", product.Price);
            if (result != null)
            {
                allProducts.Add(result);
            }
        }
        else
        {
            var result = await ProductsService.UpdateProductAsync(editingProduct.Id, product.Price, null);
            if (result != null)
            {
                var index = allProducts.FindIndex(p => p.Id == result.Id);
                if (index >= 0)
                {
                    allProducts[index] = result;
                }
            }
        }

        showForm = false;
        editingProduct = null;
    }

    private async Task ToggleActive(ProductResponse product)
    {
        var result = await ProductsService.UpdateProductAsync(product.Id, null, !product.IsActive);
        if (result != null)
        {
            var index = allProducts.FindIndex(p => p.Id == result.Id);
            if (index >= 0)
            {
                allProducts[index] = result;
            }
        }
    }

    private void ShowHistory(ProductResponse product)
    {
        historyProduct = product;
        showHistory = true;
    }
}
